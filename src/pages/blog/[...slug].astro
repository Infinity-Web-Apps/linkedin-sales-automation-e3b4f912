---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

// Estimate read time (~200 words/min)
const wordCount = post.body.split(/\s+/).length;
const readTime = Math.ceil(wordCount / 200);
---

<Base title={`${post.data.title} — Prospex Blog`} description={post.data.description}>
  <Header />
  <main>

    <!-- Article Header -->
    <header class="relative overflow-hidden py-20 md:py-28" aria-label="Article header">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, var(--color-surface-50) 0%, var(--color-surface-100) 100%);" aria-hidden="true"></div>
      <div class="absolute -top-20 -right-20 h-[400px] w-[400px] rounded-full opacity-10"
           style="background: radial-gradient(circle, #2563EB 0%, transparent 70%);" aria-hidden="true"></div>

      <div class="relative mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <!-- Tags -->
        <div class="animate-slide-up mb-6 flex flex-wrap gap-2">
          {post.data.tags.slice(0, 3).map((tag) => (
            <span class="rounded-full bg-brand-500/10 px-3 py-1 text-xs font-semibold text-brand-400">
              {tag}
            </span>
          ))}
        </div>

        <!-- Title -->
        <h1 class="animate-slide-up delay-100 font-display text-3xl font-extrabold leading-tight tracking-tight text-surface-900 md:text-4xl lg:text-5xl">
          {post.data.title}
        </h1>

        <!-- Description -->
        <p class="animate-slide-up delay-200 mt-4 text-xl leading-relaxed text-surface-700">
          {post.data.description}
        </p>

        <!-- Meta -->
        <div class="animate-slide-up delay-300 mt-6 flex items-center gap-4 border-t border-surface-200 pt-6 text-sm text-surface-700">
          <span>{post.data.author}</span>
          <span aria-hidden="true">·</span>
          <time datetime={post.data.pubDate.toISOString()}>
            {formatDate(post.data.pubDate)}
          </time>
          <span aria-hidden="true">·</span>
          <span>{readTime} min read</span>
        </div>
      </div>
    </header>

    <!-- Article Body -->
    <article class="mx-auto max-w-3xl px-4 pb-24 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none
        prose-headings:font-display prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-surface-900
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-surface-800 prose-p:leading-relaxed prose-p:mb-5
        prose-a:text-brand-400 prose-a:no-underline hover:prose-a:text-brand-300 prose-a:font-medium
        prose-strong:text-surface-900 prose-strong:font-semibold
        prose-ul:my-4 prose-ul:space-y-2 prose-li:text-surface-800
        prose-blockquote:border-l-brand-500 prose-blockquote:text-surface-700 prose-blockquote:not-italic
        prose-table:text-sm prose-th:text-surface-900 prose-td:text-surface-800
        prose-code:text-brand-400 prose-code:bg-brand-500/10 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm">
        <Content />
      </div>

      <!-- CTA Box -->
      <div class="mt-16 rounded-2xl border border-brand-500/20 bg-brand-500/10 p-8">
        <p class="text-xs font-semibold uppercase tracking-wider text-brand-400 mb-2">Prospex</p>
        <h2 class="font-display text-xl font-bold tracking-tight text-surface-900 md:text-2xl">
          Put this into practice — automatically.
        </h2>
        <p class="mt-2 text-base leading-relaxed text-surface-700">
          Prospex turns proven LinkedIn outreach tactics into automated campaigns. Build pipeline while you sleep.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a
            href="/"
            class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-6 py-2.5 text-sm font-semibold text-white hover:bg-brand-600 transition-colors duration-150"
          >
            Start free trial
          </a>
          <a
            href="/"
            class="inline-flex items-center gap-2 rounded-full border border-surface-200 bg-surface-50 px-6 py-2.5 text-sm font-semibold text-surface-900 hover:bg-surface-100 transition-colors duration-150"
          >
            See how it works
          </a>
        </div>
        <p class="mt-3 text-xs text-surface-700">No credit card required. Free 14-day trial.</p>
      </div>

      <!-- Back to blog -->
      <div class="mt-12 border-t border-surface-200 pt-8">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-sm font-semibold text-brand-400 hover:text-brand-300 transition-colors duration-150"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
          </svg>
          Back to all posts
        </a>
      </div>
    </article>

  </main>
  <Footer />
</Base>
