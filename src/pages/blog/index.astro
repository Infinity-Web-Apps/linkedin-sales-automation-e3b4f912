---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Base
  title="Prospex Blog — LinkedIn Sales & Outreach Insights"
  description="Actionable guides on LinkedIn automation, B2B outreach, and building pipeline. Written for sales teams who want results, not theory."
>
  <Header />
  <main>

    <!-- Page Header -->
    <section class="relative overflow-hidden py-24 md:py-32" aria-label="Blog header">
      <div class="absolute inset-0" style="background: linear-gradient(135deg, var(--color-surface-50) 0%, var(--color-surface-100) 100%);" aria-hidden="true"></div>
      <div class="absolute -top-24 -right-24 h-[500px] w-[500px] rounded-full opacity-10"
           style="background: radial-gradient(circle, #2563EB 0%, transparent 70%);" aria-hidden="true"></div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <div class="animate-slide-up mb-4 inline-flex items-center gap-2 rounded-full border border-brand-500/30 bg-brand-500/10 px-3 py-1.5">
            <span class="text-xs font-semibold uppercase tracking-wider text-brand-400">Prospex Blog</span>
          </div>
          <h1 class="animate-slide-up delay-100 font-display text-4xl font-extrabold tracking-tight text-surface-900 md:text-5xl">
            LinkedIn Sales, Decoded
          </h1>
          <p class="animate-slide-up delay-200 mt-4 text-xl leading-relaxed text-surface-700">
            Actionable guides on LinkedIn automation, B2B outreach, and building pipeline — written for sales teams who want results, not theory.
          </p>
        </div>
      </div>
    </section>

    <!-- Blog Post Grid -->
    <section class="py-16 md:py-24" aria-label="Blog posts">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {posts.map((post, i) => (
            <article
              class={`animate-slide-up group flex flex-col rounded-2xl border border-surface-200 bg-surface-50 p-6 transition-shadow duration-200 hover:shadow-lg delay-${(i + 1) * 100}`}
            >
              <!-- Tags -->
              <div class="mb-4 flex flex-wrap gap-2">
                {post.data.tags.slice(0, 2).map((tag) => (
                  <span class="rounded-full bg-brand-500/10 px-2.5 py-0.5 text-xs font-semibold text-brand-400">
                    {tag}
                  </span>
                ))}
              </div>

              <!-- Title -->
              <h2 class="font-display text-xl font-bold leading-snug tracking-tight text-surface-900 group-hover:text-brand-400 transition-colors duration-150">
                <a href={`/blog/${post.slug}`} class="stretched-link">
                  {post.data.title}
                </a>
              </h2>

              <!-- Description -->
              <p class="mt-3 flex-1 text-base leading-relaxed text-surface-700">
                {post.data.description}
              </p>

              <!-- Footer -->
              <div class="mt-6 flex items-center justify-between border-t border-surface-200 pt-4">
                <time datetime={post.data.pubDate.toISOString()} class="text-sm text-surface-700">
                  {formatDate(post.data.pubDate)}
                </time>
                <a
                  href={`/blog/${post.slug}`}
                  class="inline-flex items-center gap-1 text-sm font-semibold text-brand-400 hover:text-brand-300 transition-colors duration-150"
                  aria-label={`Read ${post.data.title}`}
                >
                  Read
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>

        <!-- CTA -->
        <div class="mt-20 rounded-3xl border border-brand-500/20 bg-brand-500/10 p-10 text-center md:p-16">
          <h2 class="font-display text-2xl font-bold tracking-tight text-surface-900 md:text-3xl">
            Ready to put this into practice?
          </h2>
          <p class="mt-3 text-lg text-surface-700">
            Prospex turns these tactics into automated campaigns that run while you focus on closing.
          </p>
          <a
            href="/"
            class="mt-6 inline-flex items-center gap-2 rounded-full bg-brand-500 px-8 py-3.5 text-base font-semibold text-white hover:bg-brand-600 transition-colors duration-150"
          >
            See how Prospex works
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Base>
